# Variables de entorno para Vercel (Settings → Environment Variables)

# Contraseña del modo admin
ADMIN_PASSWORD=ecolbox

# Token de GitHub con permiso de escritura en el repo
# Crear en: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# Permisos: Contents → Read and write (solo en el repo EcolboxAr)
GITHUB_TOKEN=

# Repo (opcional, este es el default)
GITHUB_REPO=lolamontesinos/EcolboxAr
